# Auto detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.prisma text eol=lf
*.sh text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Dockerfile text eol=lf

# Denote binaries (never touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
